<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Suppress EI_EXPOSE_REP2 for Spring constructor injection -->
    <Match>
        <Class name="~.*\.controller\..*"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Class name="~.*\.service\..*"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    
    <!-- Suppress EI_EXPOSE_REP and EI_EXPOSE_REP2 for ErrorResponse DTO -->
    <Match>
        <Class name="com.threeriverinsurance.model.ErrorResponse"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Class name="com.threeriverinsurance.model.ErrorResponse"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
</FindBugsFilter>
